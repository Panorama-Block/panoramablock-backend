# ===========================================
# 🚀 API Trader Joe - Configurações
# ===========================================

# 🌐 Configurações da Rede Avalanche
# URL principal da rede Avalanche (Mainnet)
RPC_URL=https://api.avax.network/ext/bc/C/rpc

# URL da rede de teste Fuji (opcional)
RPC_URL_FUJI=https://api.avax-test.network/ext/bc/C/rpc

# 🔐 Private Key para Testes (NUNCA use em produção!)
# ⚠️  ATENÇÃO: Esta é apenas para testes. Em produção, o frontend assina as mensagens.
# Substitua pela sua própria private key de teste
PRIVATE_KEY=0xdc5d66eafc371a54c9c999db024a74b6eb26b6ed12a437742348db00c4390e48

# 📍 Endereço da Wallet (será derivado automaticamente da private key)
# Opcional: pode ser definido manualmente se necessário
WALLET_ADDRESS=0x6B509c04e3caA2207b8f2A60A067a8ddED03b8d0

# 🏭 Contratos Trader Joe (Avalanche Mainnet)
TRADER_JOE_ROUTER=0x60aE616a2155Ee3d9A68541Ba4544862310933d4
TRADER_JOE_FACTORY=0x9Ad6C38BE94206cA50bb0d90783171662CD1e917

# 📋 Contrato Validation (deployado na Avalanche Mainnet)
VALIDATION_CONTRACT_ADDRESS=0x8513be0BD39c8B7d693A678ae2350Ffaa284E3cf

# 🪙 Endereços dos Tokens Principais
WAVAX_ADDRESS=0xB31f66AA3C1e785363F0875A1B74E27b85FD66c7
USDC_ADDRESS=0xB97EF9Ef8734C71904D8002F8b6Bc66Dd9c48a6E
USDT_ADDRESS=0x9702230A8Ea53601f5cD2dc00fDBc13d4dF4A8c7

# 🪙 Tokens Adicionais (opcional - você pode adicionar mais)
DAI_ADDRESS=0xd586E7F844cEa2F87f50152665BCbc2C279D8d70
WETH_ADDRESS=0x49D5c2BdFfac6CE2BFdB6640F4F80f226bc10bAB
JOE_ADDRESS=0x6e84a6216eA6dACC71eE8E6b0a5B7322EEbC0fDd
LINK_ADDRESS=0x5947BB275c521040051D82396192181b413227A3
UNI_ADDRESS=0x8eBAf22B6F053dFFeaf46f4Dd9eFA95D89ba8580

# 🪙 Tokens DeFi (opcional)
AAVE_ADDRESS=0x63a72806098Bd3D9520cC43356dD78afe5D386D9
COMP_ADDRESS=0xc3048E19E76CB9a3Aa9d77D8C03c29Fc906e2437
CRV_ADDRESS=0x249848BeCA43aC405b8102Ec90Dd5F22CA513c06

# 🪙 Tokens de Meme (opcional)
PEPE_ADDRESS=0x0000000000000000000000000000000000000000
DOGE_ADDRESS=0x0000000000000000000000000000000000000000

# 💡 Dica: Para adicionar mais tokens, use o formato:
# TOKEN_SYMBOL_ADDRESS=0x...

# 🔒 Configurações de Segurança
JWT_SECRET=b8ba74a3fc49f4d93c1c6ccd4c2a61e85035e5e875274a053c51d9a86e1fbde9
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# 🔐 Auth Service (para validação de JWT)
AUTH_SERVICE_URL=http://localhost:3001

# 🗄️ Database Gateway (opcional - centralizar snapshots/tx no Prisma gateway)
# Habilite somente quando o gateway estiver de pé com JWT/tenant configurados.
DB_GATEWAY_SYNC_ENABLED=false
DB_GATEWAY_URL=http://localhost:8080
DB_GATEWAY_SERVICE_TOKEN=
DB_GATEWAY_TENANT_ID=panorama-default
DB_GATEWAY_TIMEOUT_MS=1500

# 🖥️ Configurações do Servidor
PORT=3007
NODE_ENV=development

# 📊 Configurações de Gas (opcional)
DEFAULT_GAS_LIMIT=600000
DEFAULT_GAS_PRICE=30000000000
DEFAULT_SLIPPAGE=90

# ⏰ Configurações de Timeout
TRANSACTION_TIMEOUT=300000
API_TIMEOUT=30000
